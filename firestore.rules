rules_version = '2';

// These rules only apply to the client SDK (browser). The Admin SDK bypasses all of this.
// Deploy with: firebase deploy --only firestore:rules
// Or paste into Firebase Console → Firestore → Rules tab.

service cloud.firestore {
  match /databases/{database}/documents {

    // A user can read & write their own user doc.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // A user can read & write their own profile (layout config).
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Username reservations — readable by anyone (so registration can check uniqueness),
    // but writes only happen via Admin SDK during registration. No client writes allowed.
    match /usernames/{username} {
      allow read: if true;
      allow write: if false;
    }

    // Google OAuth tokens — never accessible from the client. Admin SDK only.
    match /googleTokens/{userId} {
      allow read, write: if false;
    }
  }
}
